### Roomi API server only.
### Copy this file to `services/api/.env` on the central API server.
### The API loads env from its own working directory (pnpm dev:api runs in services/api).
### Do not copy server secrets to client-only desktop machines.
API_PORT=4100
API_HOST=0.0.0.0
CLIENT_ORIGIN=http://localhost:5175,http://127.0.0.1:5175,http://192.168.*:5175
DAILY_API_KEY=
DAILY_DOMAIN=
OLLAMA_BASE_URL=
OLLAMA_MODEL=
ROOMI_ML_API_URL=http://192.168.0.83:8080
ROOMI_ML_API_TIMEOUT_MS=5000
