{
  "name": "@roomi/desktop",
  "version": "0.1.0",
  "description": "함께 집중하는 실시간 스터디룸 Roomi 데스크톱 앱",
  "author": "Roomi Team",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "node scripts/run-dev.mjs",
    "dev:renderer": "vite src/renderer --host 0.0.0.0 --port 5175 --strictPort",
    "build": "electron-vite build",
    "build:release": "node scripts/validate-release-env.mjs && electron-vite build",
    "dist:win": "pnpm build:release && electron-builder --win nsis --x64 && node scripts/write-release-checksum.mjs",
    "dist:win:dir": "pnpm build:release && electron-builder --win dir --x64",
    "test": "vitest run",
    "test:e2e": "pnpm test:e2e:linux",
    "test:e2e:linux": "env -u ELECTRON_RUN_AS_NODE electron-vite build && xvfb-run -a env -u ELECTRON_RUN_AS_NODE playwright test -c playwright.e2e.config.ts",
    "test:e2e:local": "node scripts/run-e2e-local.mjs",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@daily-co/daily-js": "^0.91.0",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@roomi/shared": "workspace:*",
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "@playwright/test": "^1.61.1",
    "@roomi/config": "workspace:*",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "electron": "^33.2.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^3.0.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.6",
    "vitest": "^2.1.8"
  }
}
