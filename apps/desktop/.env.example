# Desktop renderer environment (loaded by electron-vite from apps/desktop/).
# Point the renderer at the central Roomi API server. Defaults to
# http://localhost:4100 when unset. Do NOT put DAILY_API_KEY here; the
# Daily key stays server-side only (services/api env).
VITE_ROOMI_API_URL=https://api.roomi.madcamp-kaist.org

# Optional ML focus prediction API. Use http://localhost:8080 when running the
# Roomi ML server locally.
VITE_ROOMI_ML_API_URL=https://api.roomiml.madcamp-kaist.org
