{
  "name": "lumi-room-ai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @lumi/api --filter @lumi/desktop dev",
