{
  "name": "lumi-room-ai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @lumi/api --filter @lumi/desktop dev",
    "dev:api": "pnpm --filter @lumi/api dev",
    "dev:desktop": "pnpm --filter @lumi/desktop dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @lumi/desktop test:e2e",
    "test:e2e:linux": "pnpm --filter @lumi/desktop test:e2e:linux",
    "test:e2e:local": "pnpm --filter @lumi/desktop test:e2e:local",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "@lumi/config": "workspace:*",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
