{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)/.codex/hooks/session_start_context.py\"",
            "statusMessage": "Loading repo context"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)/.codex/hooks/pre_tool_use_bash_guard.py\"",
            "statusMessage": "Checking Bash command policy"
          }
        ]
      },
      {
        "matcher": "^apply_patch$|^Edit$|^Write$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)/.codex/hooks/pre_tool_use_edit_branch.py\"",
            "statusMessage": "Checking branch workflow"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)/.codex/hooks/post_tool_use_bash_review.py\"",
            "statusMessage": "Reviewing Bash output"
          }
        ]
      },
      {
        "matcher": "^apply_patch$|^Edit$|^Write$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)/.codex/hooks/post_tool_use_apply_patch_review.py\"",
            "statusMessage": "Reviewing file edits"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "AI_AUTO_COMMIT=1 CODEX_AUTO_COMMIT=1 CLAUDE_AUTO_COMMIT=1 python3 \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)/.codex/hooks/stop_turn_summary.py\"",
            "statusMessage": "Summarizing turn risk"
          }
        ]
      }
    ]
  }
}
